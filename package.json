{
  "name": "tron-grid-wars",
  "version": "1.3.1",
  "private": true,
  "description": "GRID WARS - a TRON tactics game with online multiplayer",
  "type": "commonjs",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist:win": "electron-builder --win portable --x64 --publish never"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.loosecannons.gridwars",
    "productName": "GRID WARS",
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "index.html",
      "src/**/*",
      "server.js",
      "electron/**/*",
      "package.json",
      "node_modules/ws/**/*"
    ],
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "GRID-WARS-${version}-portable.exe"
    }
  }
}
